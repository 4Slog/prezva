{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "github": {
    "enabled": true,
    "autoAlias": true,
    "autoJobCancelation": true
  },
  "crons": [
    {
      "path": "/api/cron/scheduled-announcements",
      "schedule": "*/5 * * * *"
    }
  ]
}
