# ─────────────────────────────────────────
# PREZVA — Environment Variables Template
# Copy this to .env.local and fill in values
# NEVER commit .env.local
# ─────────────────────────────────────────

# Supabase — STAGING (use for development)
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.XXXXXXXXXXXXXXXX.supabase.co:5432/postgres

# Supabase — PROD (only used in Vercel production env, NOT in .env.local)
# NEXT_PUBLIC_SUPABASE_URL_PROD=https://XXXXXXXXXXXXXXXX.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD=eyXXXXXXXXXXXXXXX

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Resend (email)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@prezva.app

# App
NEXT_PUBLIC_APP_URL=http://10.0.0.60:3100
NEXT_PUBLIC_APP_NAME=Prezva

# Anthropic (Phase 2 — AI features)
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Trigger.dev (background jobs)
TRIGGER_SECRET_KEY=tr_dev_your_key_here
TRIGGER_PROJECT_REF=prezva

# Web Push VAPID (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:hello@prezva.app

# Integration encryption — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRATION_ENCRYPTION_KEY=your_base64_key

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Admin access
ADMIN_EMAILS=
SUPER_ADMIN_IDS=

# GoHighLevel (GHL) — Private Integration Token (PIT) mode; OAuth wiring deferred to GE-8
GHL_API_TOKEN=
GHL_LOCATION_ID=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_EVENTS_ENABLED=false

# GHL Embedded shell (GE-2a)
# EMBEDDED_SESSION_SECRET: secret for signing embedded session JWTs.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
EMBEDDED_SESSION_SECRET=your_strong_random_secret_here
# GHL_FRAME_ANCESTORS: space-separated list of ADDITIONAL origins allowed to embed /embedded/*.
#   https://app.gohighlevel.com is always included. Add agency white-label domains here.
#   Example: GHL_FRAME_ANCESTORS=https://app.myagency.com https://crm.partner.com
GHL_FRAME_ANCESTORS=

# GHL Embedded shell — interim auth gate (GE-2a.1)
# GHL_EMBED_LAUNCH_SECRET: pre-shared secret added as ?k=<value> to the GHL Custom Menu Link URL.
#   Matched via SHA-256 + timingSafeEqual before any session is minted.
#   Replace with GHL-signed SSO JWT verification at GE-8 (Marketplace install).
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
GHL_EMBED_LAUNCH_SECRET=your_strong_random_secret_here

# GHL Webhook — payment dispatcher (GE-4)
# GHL_WEBHOOK_SECRET: shared secret appended as ?secret=<value> to the GHL workflow webhook URL.
#   Verified via timingSafeEqual on every inbound POST before any processing.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
GHL_WEBHOOK_SECRET=
