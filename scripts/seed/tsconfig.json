{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["es2022"],
    "types": ["node"],
    "noEmit": true,
    "jsx": "preserve",
    "isolatedModules": false,
    "incremental": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "../../node_modules"]
}
